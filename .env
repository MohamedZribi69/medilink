# Optionnel : expéditeur des e-mails (événements annulés, etc.). Par défaut : noreply@medilink.local (config/services.yaml)
# MAILER_FROM=noreply@medilink.local

# Mailer : obligatoire pour l'envoi d'e-mails (reçus dons, événements annulés).
# En dev, null://null n'envoie pas vraiment les e-mails (pas d'erreur).
# En prod, utilise un DSN SMTP réel (ex: smtp://user:pass@smtp.example.com:465).
MAILER_DSN=null://null
MAILER_FROM=rahmahabeshi0108@medilink.local

# Optionnel : clé API Hugging Face pour la génération automatique de descriptions d'événements (admin)
# HUGGINGFACE_API_KEY=your_key_here
