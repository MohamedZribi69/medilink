<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{% block title %}MediLink - BackOffice{% endblock %}</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&family=Roboto:wght@300;400;500&display=swap" rel="stylesheet">
  <style>{{ include('admin/_styles.html.twig') }}</style>
</head>
<body>
<aside class="sidebar" id="sidebar">
  <div class="sidebar-logo">
    <div class="sidebar-logo-icon">
      <i class="fas fa-heartbeat"></i>
    </div>
    <div class="sidebar-logo-text">
      MediLink
      <small>ADMINISTRATION</small>
    </div>
  </div>

  <nav class="sidebar-nav">
    <div class="sidebar-section">
      <div class="sidebar-section-title">Tableau de bord</div>
      <a href="{{ path('admin_users_index') }}" class="{% if app.request.attributes.get('_route') starts with 'admin_users' %}active{% endif %}">
        <i class="fa-solid fa-users"></i>
        <span>Utilisateurs</span>
      </a>
      <a href="{{ path('admin_events_index') }}" class="{% if app.request.attributes.get('_route') starts with 'admin_events' %}active{% endif %}">
        <i class="fa-solid fa-calendar-days"></i>
        <span>Événements</span>
      </a>
    </div>
    <div class="sidebar-section">
      <div class="sidebar-section-title">Gestion médicale</div>
      <a href="{{ path('admin_rendezvous_index') }}" class="{% if app.request.attributes.get('_route') starts with 'admin_rendezvous' %}active{% endif %}">
        <i class="fa-solid fa-calendar-check"></i>
        <span>Rendez-vous</span>
      </a>
      <a href="{{ path('admin_disponibilites_index') }}" class="{% if app.request.attributes.get('_route') starts with 'admin_disponibilites' %}active{% endif %}">
        <i class="fa-solid fa-eye"></i>
        <span>Voir disponibilités</span>
      </a>
    </div>
  </nav>

  <div class="sidebar-user">
    <i class="fas fa-user-circle"></i>
    <span>{{ app.user ? app.user.fullName : 'Admin' }}</span>
  </div>
  <div class="sidebar-logout">
    <a href="{{ path('app_logout') }}">
      <i class="fa-solid fa-right-from-bracket"></i>
      <span>Déconnexion</span>
    </a>
  </div>
</aside>

<div class="main-wrapper">
  <main class="main-content">
    <button class="mobile-menu-btn" aria-label="Menu" onclick="document.getElementById('sidebar').classList.toggle('open')">
      <i class="fas fa-bars"></i>
    </button>

    <div class="main-header">
      <h1>{% block page_title %}Administration{% endblock %}</h1>
      <div class="main-date">{{ "now"|date("d/m/Y") }} - {{ "now"|date("H:i") }}</div>
    </div>

    <div class="container">
      {% for label, messages in app.flashes %}
        {% for message in messages %}
          <div class="flash flash-{{ label }}">
            <strong>{% if label == 'success' %}✓{% elseif label == 'error' %}⚠{% else %}ℹ{% endif %}</strong> {{ message }}
          </div>
        {% endfor %}
      {% endfor %}
      {% block body %}{% endblock %}
    </div>
  </main>
</div>
</body>
</html>
