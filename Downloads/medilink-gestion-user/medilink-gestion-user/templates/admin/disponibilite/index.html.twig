{% extends 'admin/base.html.twig' %}

{% block title %}MediLink - Consultation des disponibilités{% endblock %}

{% block body %}
<section class="section active">
  <div class="section-header">
    <h2><i class="fa-solid fa-clock"></i> Disponibilités</h2>
    <p>Consultation des disponibilités créées par les médecins. Seul le médecin peut créer, modifier ou supprimer ses disponibilités.</p>
  </div>

  <div class="toolbar" style="margin-bottom: 15px;">
    <a href="{{ path('admin_rendezvous_index') }}" class="btn-secondary">
      <i class="fa-solid fa-calendar-check"></i> Retour aux rendez-vous
    </a>
  </div>

  <div class="table-container">
    <table>
      <thead>
        <tr>
          <th>Médecin</th>
          <th>Date</th>
          <th>Heure début</th>
          <th>Heure fin</th>
          <th>Statut</th>
        </tr>
      </thead>
      <tbody>
        {% for d in disponibilites %}
          <tr>
            <td>{{ d.medecin ? d.medecin.fullName : '-' }}</td>
            <td>{{ d.date|date('d/m/Y') }}</td>
            <td>{{ d.heureDebut|date('H:i') }}</td>
            <td>{{ d.heureFin|date('H:i') }}</td>
            <td>
              <span class="badge badge-{{ d.status == 'reservee' ? 'success' : (d.status == 'annulee' ? 'error' : '') }}">
                {{ statutsLabels[d.status] ?? d.status }}
              </span>
            </td>
          </tr>
        {% else %}
          <tr>
            <td colspan="5">Aucune disponibilité enregistrée. Les médecins les créent depuis leur espace.</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</section>
{% endblock %}
