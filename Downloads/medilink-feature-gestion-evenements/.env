###> symfony/mailer ###
# null = aucun envoi (en dev une copie est enregistrée dans var/log/emails/)
MAILER_DSN=null://null
# Pour recevoir de vrais e-mails, utilisez un SMTP. Exemples :
# Mailtrap (test, gratuit) : https://mailtrap.io → SMTP → copier le DSN
#   MAILER_DSN=smtp://USER:PASS@sandbox.smtp.mailtrap.io:2525
# Gmail (avec mot de passe d'application) :
#   MAILER_DSN=smtp://votreemail@gmail.com:MOT_DE_PASSE_APP@smtp.gmail.com:587
# MAILER_FROM=noreply@medilink.tn
###< symfony/mailer ###

###> Hugging Face (génération de description d'événement par IA) ###
