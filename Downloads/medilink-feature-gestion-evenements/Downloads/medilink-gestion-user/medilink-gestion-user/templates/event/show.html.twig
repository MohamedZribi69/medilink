{% extends 'event/base.html.twig' %}

{% block title %}{{ evenement.titre }} - MediLink{% endblock %}

{% block body %}
<section class="section active">
  <div class="section-header">
    <h2><i class="fa-solid fa-calendar-days"></i> {{ evenement.titre }}</h2>
    <p>{{ evenement.dateEvenement|date('d/m/Y') }} — {{ evenement.lieu }} — {{ evenement.type }}</p>
  </div>

  {% if evenement.photo %}
    <div class="table-container" style="margin-bottom: 24px; padding: 0; overflow: hidden;">
      <img src="{{ '/uploads/events/' ~ evenement.photo }}" alt="{{ evenement.titre }}" style="width: 100%; max-height: 400px; object-fit: cover; display: block;" />
    </div>
  {% endif %}

  <div class="table-container" style="margin-bottom: 24px;">
    <div style="padding: 20px;">
      {% if evenement.description %}
        <p style="white-space: pre-wrap;">{{ evenement.description }}</p>
      {% else %}
        <p style="color: var(--dark-gray);">Aucune description.</p>
      {% endif %}
    </div>
  </div>

  {% if form %}
    <div class="table-container" style="max-width: 560px;">
      <div style="padding: 20px;">
        <h3 style="margin-bottom: 16px; color: var(--primary-color);"><i class="fa-solid fa-user-plus"></i> Participer à cet événement</h3>
        <p style="margin-bottom: 16px; color: var(--dark-gray);">Remplissez le formulaire ci-dessous pour vous inscrire.</p>

        {{ form_start(form, { attr: { novalidate: 'novalidate' } }) }}
        <div class="form-group">
          <label for="{{ form.commentaire.vars.id }}">Commentaire (optionnel)</label>
          {{ form_widget(form.commentaire, { attr: { class: 'input', placeholder: 'Ex: Je souhaite participer avec un accompagnant...' } }) }}
          {{ form_errors(form.commentaire) }}
        </div>
        <button type="submit" class="btn-primary">
          <i class="fa-solid fa-check"></i> Confirmer ma participation
        </button>
        {{ form_end(form) }}
      </div>
    </div>
  {% else %}
    <div class="card">
      <strong><i class="fa-solid fa-check-circle"></i> Vous êtes inscrit à cet événement.</strong>
      {% if participation.commentaire %}
        <p style="margin-top: 10px;">Votre commentaire : {{ participation.commentaire }}</p>
      {% endif %}
      <p style="margin-top: 8px; color: var(--dark-gray);">Statut : {{ participation.statut == 'confirme' ? 'Confirmé' : (participation.statut == 'annule' ? 'Annulé' : 'En attente') }}</p>
    </div>
  {% endif %}

  <p style="margin-top: 20px;">
    <a href="{{ path('app_events_index') }}" class="btn-secondary">
      <i class="fa-solid fa-arrow-left"></i> Retour à la liste des événements
    </a>
  </p>
</section>
{% endblock %}
