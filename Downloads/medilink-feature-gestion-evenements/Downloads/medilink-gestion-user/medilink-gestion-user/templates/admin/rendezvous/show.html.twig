{% extends 'admin/base.html.twig' %}

{% block title %}Détail du rendez-vous - MediLink{% endblock %}

{% block body %}
<section class="section active">
  <div class="section-header">
    <h2><i class="fa-solid fa-calendar-check"></i> Détail du rendez-vous</h2>
    <p>Informations complètes du rendez-vous n°{{ rendezVous.id }}</p>
  </div>

  <div class="table-container" style="max-width: 640px; padding: 24px;">
    <table style="border: none;">
      <tbody>
        <tr>
          <th style="width: 180px;">Disponibilité</th>
          <td>
            {{ rendezVous.disponibilite.date|date('d/m/Y') }}
            {{ rendezVous.disponibilite.heureDebut|date('H:i') }} - {{ rendezVous.disponibilite.heureFin|date('H:i') }}
          </td>
        </tr>
        <tr>
          <th>Médecin</th>
          <td>{{ rendezVous.disponibilite.medecin ? rendezVous.disponibilite.medecin.fullName : '-' }}</td>
        </tr>
        <tr>
          <th>Patient</th>
          <td>{{ rendezVous.patient ? rendezVous.patient.fullName : '-' }}</td>
        </tr>
        <tr>
          <th>Date et heure</th>
          <td>{{ rendezVous.dateHeure|date('d/m/Y H:i') }}</td>
        </tr>
        <tr>
          <th>Statut</th>
          <td>
            <span class="badge badge-{{ rendezVous.statut == 'confirme' ? 'success' : (rendezVous.statut == 'annule' ? 'error' : '') }}">
              {{ statutsLabels[rendezVous.statut] ?? rendezVous.statut }}
            </span>
          </td>
        </tr>
        <tr>
          <th>Motif</th>
          <td>{{ rendezVous.motif ?: '-' }}</td>
        </tr>
        <tr>
          <th>Créé le</th>
          <td>{{ rendezVous.createdAt|date('d/m/Y H:i') }}</td>
        </tr>
      </tbody>
    </table>

    <div style="display: flex; gap: 12px; margin-top: 24px; flex-wrap: wrap;">
      <a href="{{ path('calendar_rendezvous', { id: rendezVous.id }) }}" class="btn-secondary">
        <i class="fa-solid fa-calendar-plus"></i> Ajouter au calendrier
      </a>
      <a href="{{ path('admin_rendezvous_index') }}" class="btn-secondary"><i class="fa-solid fa-arrow-left"></i> Retour</a>
      <a href="{{ path('admin_rendezvous_edit', { id: rendezVous.id }) }}" class="btn-primary"><i class="fa-solid fa-pen-to-square"></i> Modifier</a>
      <form method="post" action="{{ path('admin_rendezvous_delete', { id: rendezVous.id }) }}" style="display: inline;" onsubmit="return confirm('Supprimer ce rendez-vous ?');">
        <input type="hidden" name="_token" value="{{ csrf_token('delete_rendezvous_' ~ rendezVous.id) }}">
        <button type="submit" class="btn-secondary" style="color: var(--error-color); border-color: var(--error-color);">
          <i class="fa-solid fa-trash"></i> Supprimer
        </button>
      </form>
    </div>
  </div>
</section>
{% endblock %}
