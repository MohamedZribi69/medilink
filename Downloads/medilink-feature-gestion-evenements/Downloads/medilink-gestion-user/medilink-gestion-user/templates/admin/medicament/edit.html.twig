{% extends 'admin/base.html.twig' %}

{% block title %}Modifier {{ medicament.nom }}{% endblock %}
{% block page_title %}Médicaments{% endblock %}

{% block body %}
<section class="section active">
  <div class="section-header">
    <h2><i class="fa-solid fa-pills"></i> Modifier le médicament</h2>
    <p><a href="{{ path('admin_medicaments_index') }}"><i class="fa-solid fa-arrow-left"></i> Retour à la liste</a></p>
  </div>

  {{ form_start(form) }}
  <div class="form-row">
    <div class="form-group">
      <label for="{{ form.nom.vars.id }}">Nom</label>
      {{ form_widget(form.nom, { attr: { class: 'input', placeholder: 'Nom du médicament' } }) }}
      {{ form_errors(form.nom) }}
    </div>
    <div class="form-group">
      <label for="{{ form.quantiteStock.vars.id }}">Quantité en stock</label>
      {{ form_widget(form.quantiteStock, { attr: { class: 'input', min: 0 } }) }}
      {{ form_errors(form.quantiteStock) }}
    </div>
  </div>
  <div class="form-group">
    <label for="{{ form.description.vars.id }}">Description</label>
    {{ form_widget(form.description, { attr: { class: 'input', rows: 3 } }) }}
    {{ form_errors(form.description) }}
  </div>
  <div class="form-actions">
    <a href="{{ path('admin_medicaments_index') }}" class="btn-secondary">Annuler</a>
    <button type="submit" class="btn-primary"><i class="fa-solid fa-floppy-disk"></i> Enregistrer</button>
  </div>
  {{ form_end(form) }}
</section>
{% endblock %}
