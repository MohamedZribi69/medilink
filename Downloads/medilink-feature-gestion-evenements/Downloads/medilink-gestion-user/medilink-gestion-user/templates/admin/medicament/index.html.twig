{% extends 'admin/base.html.twig' %}

{% block title %}MediLink - Médicaments{% endblock %}
{% block page_title %}Médicaments{% endblock %}

{% block body %}
<section class="section active">
  <div class="section-header">
    <h2><i class="fa-solid fa-pills"></i> Gestion des médicaments</h2>
    <p>Ajouter, modifier et supprimer les médicaments.</p>
  </div>

  <form class="toolbar" method="get" action="{{ path('admin_medicaments_index') }}">
    <div class="searchbox">
      <i class="fa-solid fa-magnifying-glass"></i>
      <input name="q" value="{{ q }}" type="text" placeholder="Rechercher par nom ou description..." />
    </div>
    <a class="btn-secondary" href="{{ path('admin_medicaments_index') }}">
      <i class="fa-solid fa-rotate-left"></i> Reset
    </a>
    <a href="{{ path('admin_medicaments_new') }}" class="btn-primary">
      <i class="fa-solid fa-plus"></i> Ajouter un médicament
    </a>
  </form>

  <div class="table-container">
    <table>
      <thead>
        <tr>
          <th>Nom</th>
          <th>Description</th>
          <th>Quantité stock</th>
          <th style="width: 140px;">Actions</th>
        </tr>
      </thead>
      <tbody>
        {% for m in medicaments %}
          <tr>
            <td><strong>{{ m.nom }}</strong></td>
            <td>{{ (m.description|default('-'))|length > 80 ? (m.description|default('-'))|slice(0, 80) ~ '...' : (m.description|default('-')) }}</td>
            <td>{{ m.quantiteStock }}</td>
            <td>
              <div class="actions">
                <a class="icon-btn" title="Modifier" href="{{ path('admin_medicaments_edit', { id: m.id }) }}">
                  <i class="fa-solid fa-pen-to-square"></i>
                </a>
                <form method="post" action="{{ path('admin_medicaments_delete', { id: m.id }) }}" style="display:inline" onsubmit="return confirm('Supprimer ce médicament ?');">
                  <input type="hidden" name="_token" value="{{ csrf_token('delete_medicament_' ~ m.id) }}">
                  <button class="icon-btn" title="Supprimer" type="submit">
                    <i class="fa-solid fa-trash"></i>
                  </button>
                </form>
              </div>
            </td>
          </tr>
        {% else %}
          <tr>
            <td colspan="4">Aucun médicament.</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</section>
{% endblock %}
