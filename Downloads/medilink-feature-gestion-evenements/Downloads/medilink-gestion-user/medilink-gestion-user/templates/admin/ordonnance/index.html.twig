{% extends 'admin/base.html.twig' %}

{% block title %}MediLink - Ordonnances{% endblock %}
{% block page_title %}Ordonnances{% endblock %}

{% block body %}
<section class="section active">
  <div class="section-header">
    <h2><i class="fa-solid fa-file-prescription"></i> Liste des ordonnances</h2>
    <p>Consultation en lecture seule des ordonnances créées par les médecins.</p>
  </div>

  <div class="table-container">
    <table>
      <thead>
        <tr>
          <th>Date</th>
          <th>Médecin</th>
          <th>Patient</th>
          <th>Médicaments</th>
          <th style="width: 100px;">Action</th>
        </tr>
      </thead>
      <tbody>
        {% for o in ordonnances %}
          <tr>
            <td>{{ o.dateCreation|date('d/m/Y H:i') }}</td>
            <td>{{ o.medecin ? o.medecin.fullName : '-' }}</td>
            <td>{{ o.patient ? o.patient.fullName : '-' }}</td>
            <td>
              {% for om in o.ordonnanceMedicaments %}
                {{ om.medicament.nom }} (x{{ om.quantite }}){% if not loop.last %}, {% endif %}
              {% else %}
                -
              {% endfor %}
            </td>
            <td>
              <a class="icon-btn" title="Voir" href="{{ path('admin_ordonnances_show', { id: o.id }) }}">
                <i class="fa-solid fa-eye"></i>
              </a>
            </td>
          </tr>
        {% else %}
          <tr>
            <td colspan="5">Aucune ordonnance.</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</section>
{% endblock %}
