<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{% block title %}MediLink - Espace Médecin{% endblock %}</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&family=Roboto:wght@300;400;500&display=swap" rel="stylesheet">
  <style>{{ include('_styles_front.html.twig') }}</style>
</head>
<body>
<header class="header">
  <div class="container">
    <div class="logo">
      <i class="fas fa-heartbeat"></i>
      <h1>Medi<span>Link</span></h1>
    </div>
    <nav class="nav">
      <a href="{{ path('medecin_index') }}" class="{% if app.request.attributes.get('_route') == 'medecin_index' %}active{% endif %}">
        <i class="fa-solid fa-clock"></i> Mes disponibilités
      </a>
      <a href="{{ path('medecin_ordonnances_index') }}" class="{% if app.request.attributes.get('_route') starts with 'medecin_ordonnances' %}active{% endif %}">
        <i class="fa-solid fa-file-prescription"></i> Ordonnances
      </a>
      <a href="{{ path('medecin_medicaments_index') }}" class="{% if app.request.attributes.get('_route') == 'medecin_medicaments_index' %}active{% endif %}">
        <i class="fa-solid fa-pills"></i> Médicaments
      </a>
      <div class="user-info">
        <i class="fas fa-user-md"></i>
        <span>{{ app.user ? app.user.fullName : 'Médecin' }}</span>
      </div>
      <a href="{{ path('app_logout') }}" title="Déconnexion">
        <i class="fa-solid fa-right-from-bracket"></i>
      </a>
    </nav>
    <button class="mobile-menu-btn" aria-label="Menu"><i class="fas fa-bars"></i></button>
  </div>
</header>

<main class="main-content">
  <div class="container">
    {% for label, messages in app.flashes %}
      {% for message in messages %}
        <div class="flash flash-{{ label }}">
          <strong>{% if label == 'success' %}✓{% elseif label == 'error' %}⚠{% else %}ℹ{% endif %}</strong> {{ message }}
        </div>
      {% endfor %}
    {% endfor %}
    {% block body %}{% endblock %}
  </div>
</main>

<footer class="footer">
  <div class="container">
    <p>MediLink &copy; 2026 - Espace médecin</p>
  </div>
</footer>

<script>
  document.querySelector('.mobile-menu-btn')?.addEventListener('click', function() {
    const nav = document.querySelector('.nav');
    nav.style.display = nav.style.display === 'flex' ? 'none' : 'flex';
  });
</script>
</body>
</html>
