{% extends 'admin/base.html.twig' %}

{% block title %}Tableau de bord - MediLink{% endblock %}
{% block page_title %}Tableau de bord{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-primary shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">Total événements</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">{{ stats.total_events }}</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-calendar-alt fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-success shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-success text-uppercase mb-1">À venir</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">{{ stats.a_venir }}</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-calendar-check fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-warning shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">Participations en attente</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">{{ participations_en_attente|length }}</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-user-clock fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12 mb-4">
            <div class="card shadow">
                <div class="card-header py-3 d-flex justify-content-between align-items-center">
                    <h6 class="m-0 font-weight-bold text-primary">
                        <i class="fas fa-calendar-days me-2"></i> Gestion des événements
                    </h6>
                    <a href="{{ path('admin_events_index') }}" class="btn btn-sm btn-primary">
                        <i class="fas fa-list me-1"></i> Voir tous les événements
                    </a>
                </div>
                <div class="card-body">
                    {% if participations_en_attente is not empty %}
                        <p class="text-muted mb-3">
                            <i class="fas fa-info-circle me-1"></i>
                            {{ participations_en_attente|length }} participation(s) en attente de validation.
                            <a href="{{ path('admin_events_index') }}">Gérer les événements et participants</a>.
                        </p>
                    {% endif %}
                    {% if a_venir is empty and evenements is empty %}
                        <div class="text-center py-4">
                            <i class="fas fa-calendar-plus fa-2x text-muted mb-3"></i>
                            <p class="text-muted">Aucun événement. <a href="{{ path('admin_events_new') }}">Créer un événement</a>.</p>
                        </div>
                    {% else %}
                        <p class="text-muted mb-0">
                            <a href="{{ path('admin_events_new') }}" class="btn btn-primary">
                                <i class="fas fa-plus me-1"></i> Nouvel événement
                            </a>
                        </p>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
