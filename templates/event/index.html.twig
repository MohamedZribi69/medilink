{% extends 'event/base.html.twig' %}

{% block title %}Événements - MediLink{% endblock %}

{% block event_styles %}
.event-cards {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: 24px;
  margin-top: 24px;
}
.event-card {
  background: var(--white);
  border-radius: 12px;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  overflow: hidden;
  border: 1px solid var(--medium-gray);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
  display: flex;
  flex-direction: column;
}
.event-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 8px 28px rgba(26, 115, 232, 0.15);
}
.event-card-image {
  width: 100%;
  height: 180px;
  object-fit: cover;
  background: var(--light-gray);
}
.event-card-header {
  background: linear-gradient(135deg, var(--primary-color), #0d62d9);
  color: var(--white);
  padding: 20px;
  text-align: center;
}
.event-card-header h3 {
  margin: 0;
  font-size: 1.25rem;
  font-weight: 600;
  line-height: 1.3;
}
.event-card-header .event-type {
  display: inline-block;
  margin-top: 8px;
  font-size: 0.8rem;
  opacity: 0.95;
  font-weight: 500;
}
.event-card-body {
  padding: 20px;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.event-card-meta {
  display: flex;
  flex-direction: column;
  gap: 8px;
  color: var(--dark-gray);
  font-size: 0.95rem;
}
.event-card-meta span {
  display: flex;
  align-items: center;
  gap: 10px;
}
.event-card-meta i {
  width: 20px;
  color: var(--primary-color);
  font-size: 0.9rem;
}
.event-card-desc {
  font-size: 0.9rem;
  color: var(--dark-gray);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
  flex: 1;
  min-height: 4.2em;
}
.event-card-footer {
  padding: 16px 20px;
  border-top: 1px solid var(--light-gray);
  background: var(--light-gray);
}
.event-card .btn-participate {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  width: 100%;
  padding: 12px 20px;
  background: var(--secondary-color);
  color: var(--white);
  border: none;
  border-radius: 8px;
  font-weight: 600;
  font-size: 1rem;
  text-decoration: none;
  cursor: pointer;
  transition: background 0.2s, transform 0.15s;
}
.event-card .btn-participate:hover {
  background: #0a6b5a;
  transform: translateY(-1px);
  color: var(--white);
}
.event-empty {
  text-align: center;
  padding: 48px 24px;
  background: var(--white);
  border-radius: 12px;
  color: var(--dark-gray);
  font-size: 1.1rem;
}
.event-empty i {
  font-size: 3rem;
  color: var(--medium-gray);
  margin-bottom: 16px;
  display: block;
}
{% endblock %}

{% block body %}
<section class="section active">
  <div class="section-header">
    <h2><i class="fa-solid fa-calendar-days"></i> Événements</h2>
    <p>Consultez les événements et inscrivez-vous à ceux qui vous intéressent.</p>
  </div>

  {% if evenements is empty %}
    <div class="event-empty">
      <i class="fa-solid fa-calendar-xmark"></i>
      Aucun événement pour le moment.
    </div>
  {% else %}
    <div class="event-cards">
      {% for e in evenements %}
        <article class="event-card">
          {% if e.photo %}
            <img class="event-card-image" src="{{ '/uploads/events/' ~ e.photo }}" alt="{{ e.titre }}" />
          {% endif %}
          <div class="event-card-header{{ e.photo ? '' : ' no-photo' }}">
            <h3>{{ e.titre }}</h3>
            <span class="event-type">{{ e.type }}</span>
          </div>
          <div class="event-card-body">
            <div class="event-card-meta">
              <span><i class="fa-solid fa-calendar"></i> {{ e.dateEvenement|date('d/m/Y') }}</span>
              <span><i class="fa-solid fa-location-dot"></i> {{ e.lieu }}</span>
            </div>
            {% if e.description %}
              <p class="event-card-desc">{{ e.description }}</p>
            {% else %}
              <p class="event-card-desc" style="color: var(--medium-gray); font-style: italic;">Aucune description.</p>
            {% endif %}
          </div>
          <div class="event-card-footer">
            <a href="{{ path('app_events_show', { id: e.id }) }}" class="btn-participate">
              <i class="fa-solid fa-user-plus"></i> Participer
            </a>
          </div>
        </article>
      {% endfor %}
    </div>
  {% endif %}
</section>
{% endblock %}
