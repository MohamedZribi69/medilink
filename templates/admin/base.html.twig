{# templates/admin/base.html.twig #}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}MediLink Admin{% endblock %}</title>
    
    {% block stylesheets %}
        <!-- Bootstrap 5 -->
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        <!-- Font Awesome -->
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
        <!-- Google Fonts -->
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
        <!-- CSS Admin -->
        <link rel="stylesheet" href="{{ asset('css/admin.css') }}">
        {% block styles %}{% endblock %}
    {% endblock %}
</head>
<body>
    <div class="admin-container">
        <!-- Sidebar -->
        <aside class="sidebar">
            <!-- Logo -->
            <div class="sidebar-header">
                <div class="logo">
                    <div class="logo-icon">
                        <i class="fas fa-shield-alt"></i>
                    </div>
                    <div>
                        <div class="logo-text">MediLink</div>
                        <div class="logo-subtext">Administration</div>
                    </div>
                </div>
            </div>

            <!-- Navigation -->
            <div class="nav-section">
                <div class="nav-section-title">Tableau de bord</div>
                <a href="{{ path('admin_dashboard') }}" class="nav-item {{ app.request.get('_route') == 'admin_dashboard' ? 'active' : '' }}">
                    <i class="fas fa-tachometer-alt"></i>
                    <span>Vue d'ensemble</span>
                </a>
            </div>

            <div class="nav-section">
                <div class="nav-section-title">Gestion des dons</div>
                <a href="{{ path('admin_don_index', {'statut': 'en_attente'}) }}" 
                   class="nav-item {{ app.request.get('_route') == 'admin_don_index' and app.request.query.get('statut') == 'en_attente' ? 'active' : '' }}">
                    <i class="fas fa-clock"></i>
                    <span>En attente</span>
                    {% if stats is defined and stats.en_attente > 0 %}
                        <span class="badge bg-warning">{{ stats.en_attente }}</span>
                    {% endif %}
                </a>
                <a href="{{ path('admin_don_index', {'statut': 'valide'}) }}" 
                   class="nav-item {{ app.request.get('_route') == 'admin_don_index' and app.request.query.get('statut') == 'valide' ? 'active' : '' }}">
                    <i class="fas fa-check-circle"></i>
                    <span>Validés</span>
                </a>
                <a href="{{ path('admin_don_index', {'statut': 'rejete'}) }}" 
                   class="nav-item {{ app.request.get('_route') == 'admin_don_index' and app.request.query.get('statut') == 'rejete' ? 'active' : '' }}">
                    <i class="fas fa-times-circle"></i>
                    <span>Rejetés</span>
                </a>
                <a href="{{ path('admin_don_index', {'statut': 'tous'}) }}" 
                   class="nav-item {{ app.request.get('_route') == 'admin_don_index' and app.request.query.get('statut') == 'tous' ? 'active' : '' }}">
                    <i class="fas fa-list"></i>
                    <span>Tous les dons</span>
                </a>
            </div>

            <div class="nav-section">
                <div class="nav-section-title">Site public</div>
                {# mode=public pour voir le site SANS interface donateur #}
                <a href="{{ path('front_home', {'mode': 'public'}) }}" class="nav-item" target="_blank">
                    <i class="fas fa-external-link-alt"></i>
                    <span>Voir le site</span>
                </a>
            </div>

            <!-- Footer -->
            <div class="sidebar-footer">
                <div class="user-info">
                    <div class="user-avatar">
                        <i class="fas fa-user-shield"></i>
                    </div>
                    <div class="user-details">
                        <div class="user-name">Administrateur</div>
                        <div class="user-role">Panel de gestion</div>
                    </div>
                    <a href="{{ path('front_home', {'mode': 'public'}) }}" class="btn-icon" title="Retour au site">
                        <i class="fas fa-sign-out-alt"></i>
                    </a>
                </div>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="main-content">
            <!-- En-tête -->
            <div class="main-header">
                <div class="header-info">
                    <h1 class="h4 mb-0">
                        {% block page_title %}{% endblock %}
                    </h1>
                    <div class="text-muted small">
                        <i class="fas fa-calendar me-1"></i>
                        {{ "now"|date("d/m/Y") }} • {{ "now"|date("H:i") }}
                    </div>
                </div>
                <div class="header-actions">
                    <a href="{{ path('front_home', {'mode': 'public'}) }}" target="_blank" class="btn btn-outline-primary btn-sm">
                        <i class="fas fa-external-link-alt me-1"></i> Voir le site
                    </a>
                </div>
            </div>

            <!-- Messages flash -->
            {% for message in app.flashes('success') %}
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="fas fa-check-circle me-2"></i> {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}
            
            {% for message in app.flashes('error') %}
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="fas fa-exclamation-circle me-2"></i> {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}

            <!-- Contenu principal -->
            {% block body %}{% endblock %}
        </main>
    </div>

    {% block javascripts %}
        <!-- Bootstrap 5 JS -->
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
        <!-- JavaScript Admin -->
        <script src="{{ asset('js/admin.js') }}"></script>
        {% block page_scripts %}{% endblock %}
    {% endblock %}
</body>
</html>