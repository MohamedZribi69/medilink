{# templates/admin/don/edit.html.twig #}
{% extends 'admin/base.html.twig' %}

{% block title %}Modifier le don #{{ don.id }} - Admin{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">
            <i class="fas fa-edit me-2"></i> Modifier le don #{{ don.id }}
        </h1>
        <div class="btn-group">
            <a href="{{ path('admin_don_index') }}" class="btn btn-secondary">
                <i class="fas fa-arrow-left me-1"></i> Annuler
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">
                        <i class="fas fa-edit me-2"></i> Formulaire de modification
                    </h6>
                </div>
                <div class="card-body">
                    {{ form_start(form) }}
                    
                    <div class="row mb-3">
                        <div class="col-md-6">
                            {{ form_row(form.categorie, {
                                'attr': {'class': 'form-control'},
                                'label': 'Catégorie'
                            }) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_row(form.quantite, {
                                'attr': {'class': 'form-control', 'min': 1},
                                'label': 'Quantité'
                            }) }}
                        </div>
                    </div>

                    <div class="mb-3">
                        {{ form_row(form.articleDescription, {
                            'attr': {'class': 'form-control'},
                            'label': 'Description de l\'article'
                        }) }}
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            {{ form_row(form.unite, {
                                'attr': {'class': 'form-control'},
                                'label': 'Unité de mesure'
                            }) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_row(form.etat, {
                                'attr': {'class': 'form-control'},
                                'label': 'État du don'
                            }) }}
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            {{ form_row(form.niveauUrgence, {
                                'attr': {'class': 'form-control'},
                                'label': 'Niveau d\'urgence'
                            }) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_row(form.statut, {
                                'attr': {'class': 'form-control'},
                                'label': 'Statut'
                            }) }}
                        </div>
                    </div>

                    <div class="mb-3">
                        {{ form_row(form.detailsSupplementaires, {
                            'attr': {'class': 'form-control', 'rows': 3},
                            'label': 'Détails supplémentaires'
                        }) }}
                    </div>

                    <div class="mb-3">
                        {{ form_row(form.dateExpiration, {
                            'attr': {'class': 'form-control'},
                            'label': 'Date d\'expiration'
                        }) }}
                    </div>

                    <div class="d-flex justify-content-end">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save me-1"></i> Enregistrer les modifications
                        </button>
                    </div>

                    {{ form_end(form) }}
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <!-- Informations -->
            <div class="card shadow">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-info">
                        <i class="fas fa-info-circle me-2"></i> Informations
                    </h6>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <strong>ID :</strong> #{{ don.id }}
                    </div>
                    <div class="mb-3">
                        <strong>Soumis le :</strong> {{ don.dateSoumission|date('d/m/Y H:i') }}
                    </div>
                    <div class="mb-3">
                        <strong>Statut actuel :</strong>
                        <span class="badge bg-{{ don.couleurStatut }}">
                            {{ don.statutLabel }}
                        </span>
                    </div>
                    <div class="alert alert-warning">
                        <i class="fas fa-exclamation-triangle me-2"></i>
                        <strong>Attention :</strong> La modification change immédiatement le don.
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}