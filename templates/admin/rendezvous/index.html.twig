{% extends 'admin/base.html.twig' %}

{% block title %}MediLink - Gestion des rendez-vous{% endblock %}
{% block page_title %}Rendez-vous{% endblock %}

{% block body %}
<section class="section active">
  <div class="section-header">
    <p class="mb-0 text-secondary">Consulter, créer et suivre les rendez-vous médicaux. Une disponibilité ne peut être réservée que pour un seul rendez-vous.</p>
  </div>

  <form class="toolbar" method="get" action="{{ path('admin_rendezvous_index') }}">
    <div class="searchbox">
      <i class="fa-solid fa-magnifying-glass"></i>
      <input name="q" value="{{ filters.q }}" type="text" placeholder="Rechercher par patient, médecin, motif..." />
    </div>
    <div class="filters">
      <select name="statut" class="input" style="min-width: 140px;">
        <option value="">Tous les statuts</option>
        {% for label, code in statuts %}
          <option value="{{ code }}" {% if filters.statut == code %}selected{% endif %}>{{ label }}</option>
        {% endfor %}
      </select>
      <a class="btn-secondary" href="{{ path('admin_rendezvous_index', { q: filters.q, statut: filters.statut, ordre: 'asc' }) }}">
        <i class="fa-solid fa-filter"></i> Date croissant
      </a>
      <a class="btn-secondary" href="{{ path('admin_rendezvous_index') }}">
        <i class="fa-solid fa-rotate-left"></i> Reset
      </a>
    </div>
    <a href="{{ path('admin_disponibilites_index') }}" class="btn-secondary" title="Voir les disponibilités">
      <i class="fa-solid fa-clock"></i> Voir disponibilités
    </a>
    <a href="{{ path('admin_rendezvous_new') }}" class="btn-primary">
      <i class="fa-solid fa-plus"></i> Nouveau rendez-vous
    </a>
  </form>

  <div class="table-container">
    <table class="table table-hover align-middle">
      <thead>
        <tr>
          <th>Disponibilité</th>
          <th>Médecin</th>
          <th>Patient</th>
          <th>Date et heure</th>
          <th>Statut</th>
          <th class="text-end" style="width: 240px;">Actions</th>
        </tr>
      </thead>
      <tbody>
        {% for r in pagination %}
          <tr>
            <td>
              {{ r.disponibilite.date|date('d/m/Y') }} - {{ r.disponibilite.heureDebut|date('H:i') }} à {{ r.disponibilite.heureFin|date('H:i') }}
            </td>
            <td>{{ r.disponibilite.medecin ? r.disponibilite.medecin.fullName : '-' }}</td>
            <td>{{ r.patient ? r.patient.fullName : '-' }}</td>
            <td>{{ r.dateHeure|date('d/m/Y H:i') }}</td>
            <td>
              <span class="badge badge-{{ r.statut == 'confirme' ? 'success' : (r.statut == 'annule' ? 'error' : (r.statut == 'termine' ? 'default' : 'warning')) }}">
                {{ statutsLabels[r.statut] ?? r.statut }}
              </span>
            </td>
            <td>
              <div class="actions">
                <a class="btn-calendar-icon" href="{{ path('calendar_rendezvous', { id: r.id }) }}" title="Ajouter au calendrier">
                  <i class="fa-solid fa-calendar-plus"></i>
                </a>
                <a class="icon-btn" title="Voir" href="{{ path('admin_rendezvous_show', { id: r.id }) }}">
                  <i class="fa-solid fa-eye"></i>
                </a>
                <a class="icon-btn" title="Modifier" href="{{ path('admin_rendezvous_edit', { id: r.id }) }}">
                  <i class="fa-solid fa-pen-to-square"></i>
                </a>
                <form method="post" action="{{ path('admin_rendezvous_delete', { id: r.id }) }}" style="display:inline" onsubmit="return confirm('Supprimer ce rendez-vous ?');">
                  <input type="hidden" name="_token" value="{{ csrf_token('delete_rendezvous_' ~ r.id) }}">
                  <button class="icon-btn icon-btn-danger" title="Supprimer" type="submit">
                    <i class="fa-solid fa-trash"></i>
                  </button>
                </form>
              </div>
            </td>
          </tr>
        {% else %}
          <tr>
            <td colspan="6">Aucun rendez-vous trouvé.</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>

  <div class="admin-pagination-bar">
    <nav class="d-flex align-items-center justify-content-between flex-wrap gap-3 py-3 px-3 rounded" aria-label="Pagination des rendez-vous">
      <div class="text-muted small mb-0">
        <strong>{{ pagination.totalItemCount }}</strong> rendez-vous au total
        {% if pagination.pageCount > 1 %}
          — Page <strong>{{ pagination.currentPageNumber }}</strong> / {{ pagination.pageCount }}
        {% endif %}
      </div>
      {% if pagination.pageCount > 1 %}
        {{ knp_pagination_render(pagination) }}
      {% else %}
        <span class="text-muted small">(une seule page)</span>
      {% endif %}
    </nav>
  </div>
</section>

<script>
  document.querySelector('select[name="statut"]')?.addEventListener('change', function() {
    this.form.submit();
  });
</script>
{% endblock %}
