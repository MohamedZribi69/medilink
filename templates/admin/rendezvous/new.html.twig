{% extends 'admin/base.html.twig' %}

{% block title %}Nouveau rendez-vous - MediLink{% endblock %}
{% block page_title %}Rendez-vous{% endblock %}

{% block body %}
<section class="section active">
  <div class="section-header">
    <p class="mb-0 text-secondary">Sélectionnez une disponibilité pour créer un rendez-vous. Les disponibilités libres sont créées par les médecins.</p>
  </div>

  {% if creneauxDisponibles is empty %}
    <div class="card" style="padding: 20px; background: #fff3cd; border-left: 4px solid var(--warning-color);">
      <strong>Aucune disponibilité.</strong> Les médecins doivent d'abord créer des disponibilités dans leur espace. Les patients peuvent également réserver directement depuis la page « Rendez-vous ».
    </div>
    <p><a href="{{ path('admin_rendezvous_index') }}" class="btn-secondary"><i class="fa-solid fa-arrow-left"></i> Retour</a></p>
  {% else %}
  <div class="table-container" style="max-width: 600px;">
    {{ form_start(form, { attr: { novalidate: 'novalidate' }, action: path('admin_rendezvous_new'), method: 'POST' }) }}
    <div style="padding: 20px;">
      {{ form_errors(form) }}
      <div class="form-group">
        <label for="{{ form.disponibilite.vars.id }}">Disponibilité</label>
        {{ form_widget(form.disponibilite, { attr: { class: 'input' } }) }}
        {{ form_errors(form.disponibilite) }}
        <p class="hint">Disponibilités libres à venir uniquement. Format : Médecin - Date Heure.</p>
      </div>
      <div class="form-group">
        <label for="{{ form.patient.vars.id }}">Patient (optionnel)</label>
        {{ form_widget(form.patient, { attr: { class: 'input' } }) }}
        {{ form_errors(form.patient) }}
      </div>
      <div class="form-group">
        <label for="{{ form.statut.vars.id }}">Statut</label>
        {{ form_widget(form.statut, { attr: { class: 'input' } }) }}
        {{ form_errors(form.statut) }}
      </div>
      <div class="form-group">
        <label for="{{ form.motif.vars.id }}">Motif</label>
        {{ form_widget(form.motif, { attr: { class: 'input' } }) }}
        {{ form_errors(form.motif) }}
      </div>
      <div style="display: flex; gap: 12px; margin-top: 20px;">
        <a href="{{ path('admin_rendezvous_index') }}" class="btn-secondary">Annuler</a>
        <button type="submit" class="btn-primary">Enregistrer</button>
      </div>
    </div>
    {{ form_end(form) }}
  </div>
  {% endif %}
</section>
{% endblock %}
