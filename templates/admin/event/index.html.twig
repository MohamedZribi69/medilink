{% extends 'admin/base.html.twig' %}

{% block title %}MediLink - Gestion des événements{% endblock %}
{% block page_title %}Gestion des événements{% endblock %}

{% block body %}
<section class="section active">
  <div class="section-header">
    <p class="mb-0 text-secondary">Créer, modifier et consulter les participants des événements.</p>
  </div>

  <form class="toolbar" method="get" action="{{ path('admin_events_index') }}">
    <div class="searchbox">
      <i class="fa-solid fa-magnifying-glass"></i>
      <input name="q" value="{{ filters.q }}" type="text" placeholder="Rechercher par titre, lieu, type..." />
    </div>
    <div class="filters">
      <a class="btn-secondary" href="{{ path('admin_events_index', { q: filters.q, ordre: 'asc' }) }}">
        <i class="fa-solid fa-filter"></i> Filtrer (date croissant)
      </a>
      <a class="btn-secondary" href="{{ path('admin_events_index', { q: filters.q }) }}">
        <i class="fa-solid fa-rotate-left"></i> Reset
      </a>
    </div>
    <a href="{{ path('admin_events_new') }}" class="btn-primary" id="btnAdd" style="text-decoration: none;">
      <i class="fa-solid fa-plus"></i> Ajouter un événement
    </a>
  </form>

  <div class="table-container">
    <table>
      <thead>
        <tr>
          <th>Titre</th>
          <th>Date</th>
          <th>Lieu</th>
          <th>Type</th>
          <th style="width: 200px;">Actions</th>
        </tr>
      </thead>
      <tbody>
        {% for e in evenements %}
          <tr>
            <td><strong>{{ e.titre }}</strong></td>
            <td>{{ e.dateEvenement|date('d/m/Y') }}</td>
            <td>{{ e.lieu }}</td>
            <td>{{ e.type }}</td>
            <td>
              <div class="actions">
                <a class="icon-btn" title="Voir les participants" href="{{ path('admin_events_participants', { id: e.id }) }}">
                  <i class="fa-solid fa-users"></i>
                </a>
                <a class="icon-btn" title="Modifier" href="{{ path('admin_events_edit', { id: e.id }) }}">
                  <i class="fa-solid fa-pen-to-square"></i>
                </a>
                <form method="post" action="{{ path('admin_events_delete', { id: e.id }) }}" style="display:inline" onsubmit="return confirm('Supprimer cet événement ?');">
                  <input type="hidden" name="_token" value="{{ csrf_token('delete_event_' ~ e.id) }}">
                  <button class="icon-btn icon-btn-danger" title="Supprimer" type="submit">
                    <i class="fa-solid fa-trash"></i>
                  </button>
                </form>
              </div>
            </td>
          </tr>
        {% else %}
          <tr>
            <td colspan="5">Aucun événement trouvé.</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>

</section>
{% endblock %}
