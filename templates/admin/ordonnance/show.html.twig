{% extends 'admin/base.html.twig' %}

{% block title %}Ordonnance #{{ ordonnance.id }} - MediLink{% endblock %}
{% block page_title %}Ordonnances{% endblock %}

{% block body %}
<section class="section active">
  <div class="section-header">
    <h2><i class="fa-solid fa-file-prescription"></i> Ordonnance #{{ ordonnance.id }}</h2>
    <p><a href="{{ path('admin_ordonnances_index') }}"><i class="fa-solid fa-arrow-left"></i> Retour à la liste</a></p>
  </div>

  <div class="card" style="max-width: 600px;">
    <p><strong>Date :</strong> {{ ordonnance.dateCreation|date('d/m/Y H:i') }}</p>
    <p><strong>Médecin :</strong> {{ ordonnance.medecin ? ordonnance.medecin.fullName : '-' }}</p>
    <p><strong>Patient :</strong> {{ ordonnance.patient ? ordonnance.patient.fullName : '-' }}</p>
    {% if ordonnance.instructions %}
      <p><strong>Instructions :</strong><br>{{ ordonnance.instructions|nl2br }}</p>
    {% endif %}
    <h3 style="margin-top: 16px;">Médicaments</h3>
    <ul>
      {% for om in ordonnance.ordonnanceMedicaments %}
        <li>{{ om.medicament.nom }} — Quantité : {{ om.quantite }}</li>
      {% else %}
        <li>Aucun médicament.</li>
      {% endfor %}
    </ul>
  </div>
</section>
{% endblock %}
