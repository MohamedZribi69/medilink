{# templates/admin/dashboard/index.html.twig #}
{% extends 'admin/base.html.twig' %}

{% block title %}Tableau de bord - MediLink{% endblock %}
{% block page_title %}Tableau de bord{% endblock %}

{% block body %}
<div class="container-fluid">
    <!-- Statistiques -->
    <div class="row mb-4">
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-primary shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                                Total dons
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">{{ stats.total }}</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-donate fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-warning shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">
                                En attente
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">{{ stats.en_attente }}</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-clock fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-success shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-success text-uppercase mb-1">
                                Validés
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">{{ stats.valides }}</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-check-circle fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-danger shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-danger text-uppercase mb-1">
                                Rejetés
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">{{ stats.rejetes }}</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-times-circle fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Graphiques Google Charts (gestion dons) -->
    <div class="row mb-4">
        <div class="col-lg-8 mb-4">
            <div class="card shadow">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">
                        <i class="fas fa-chart-line me-2"></i> Évolution des dons (12 derniers mois)
                    </h6>
                </div>
                <div class="card-body">
                    <div id="chart_monthly_dons"></div>
                </div>
            </div>
        </div>
        <div class="col-lg-4 mb-4">
            <div class="card shadow">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">
                        <i class="fas fa-chart-pie me-2"></i> Dons par catégorie
                    </h6>
                </div>
                <div class="card-body">
                    <div id="chart_by_category"></div>
                </div>
            </div>
        </div>
    </div>
    <div class="row mb-4">
        <div class="col-lg-6 mb-4">
            <div class="card shadow">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">
                        <i class="fas fa-tachometer-alt me-2"></i> Taux de validation
                    </h6>
                </div>
                <div class="card-body text-center">
                    <div id="chart_validation_rate"></div>
                </div>
            </div>
        </div>
        <div class="col-lg-6 mb-4">
            <div class="card shadow">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">
                        <i class="fas fa-star me-2"></i> Score qualité
                    </h6>
                </div>
                <div class="card-body text-center">
                    <div id="chart_quality_score"></div>
                </div>
            </div>
        </div>
    </div>

    <!-- Dons en attente -->
    <div class="row">
        <div class="col-lg-8 mb-4">
            <div class="card shadow">
                <div class="card-header py-3 d-flex justify-content-between align-items-center">
                    <h6 class="m-0 font-weight-bold text-primary">
                        <i class="fas fa-clock me-2"></i> Dons en attente de validation
                        <span class="badge bg-warning ms-2">{{ dons_en_attente|length }}</span>
                    </h6>
                    <a href="{{ path('admin_don_index', {'statut': 'en_attente'}) }}" class="btn btn-sm btn-primary">
                        <i class="fas fa-arrow-right me-1"></i> Tout voir
                    </a>
                </div>
                <div class="card-body">
                    {% if dons_en_attente is empty %}
                        <div class="text-center py-4">
                            <i class="fas fa-check-circle fa-2x text-success mb-3"></i>
                            <p class="text-muted">Aucun don en attente de validation.</p>
                        </div>
                    {% else %}
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>ID</th>
                                        <th>Description</th>
                                        <th>Catégorie</th>
                                        <th>Quantité</th>
                                        <th>Date</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for don in dons_en_attente %}
                                        <tr>
                                            <td>#{{ don.id }}</td>
                                            <td>
                                                <a href="{{ path('admin_don_show', {'id': don.id}) }}">
                                                    {{ don.articleDescription|slice(0, 30) }}...
                                                </a>
                                            </td>
                                            <td>
                                                <span class="badge" style="background-color: {{ don.categorie.couleur|default('#3498db') }}20; color: {{ don.categorie.couleur|default('#3498db') }};">
                                                    <i class="fas {{ don.categorie.icone|default('fa-box') }} me-1"></i>
                                                    {{ don.categorie.nom }}
                                                </span>
                                            </td>
                                            <td>{{ don.quantite }} {{ don.unite }}</td>
                                            <td>{{ don.dateSoumission|date('d/m/Y') }}</td>
                                            <td>
                                                <div class="btn-group btn-group-sm">
                                                    <a href="{{ path('admin_don_show', {'id': don.id}) }}" class="btn btn-info" title="Voir">
                                                        <i class="fas fa-eye"></i>
                                                    </a>
                                                    <form action="{{ path('admin_don_valider', {'id': don.id}) }}" method="post" class="d-inline">
                                                        <input type="hidden" name="_token" value="{{ csrf_token('valider' ~ don.id) }}">
                                                        <button type="submit" class="btn btn-success" title="Valider">
                                                            <i class="fas fa-check"></i>
                                                        </button>
                                                    </form>
                                                    <form action="{{ path('admin_don_rejeter', {'id': don.id}) }}" method="post" class="d-inline">
                                                        <input type="hidden" name="_token" value="{{ csrf_token('rejeter' ~ don.id) }}">
                                                        <button type="submit" class="btn btn-danger" title="Rejeter">
                                                            <i class="fas fa-times"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>

        <!-- Dons récemment validés -->
        <div class="col-lg-4 mb-4">
            <div class="card shadow">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-success">
                        <i class="fas fa-check-circle me-2"></i> Dons récemment validés
                    </h6>
                </div>
                <div class="card-body">
                    {% if dons_recents_valides is empty %}
                        <div class="text-center py-4">
                            <i class="fas fa-inbox fa-2x text-muted mb-3"></i>
                            <p class="text-muted">Aucun don validé récemment.</p>
                        </div>
                    {% else %}
                        <div class="list-group list-group-flush">
                            {% for don in dons_recents_valides %}
                                <div class="list-group-item border-0 px-0">
                                    <div class="d-flex align-items-center mb-2">
                                        <div class="flex-shrink-0">
                                            <div class="rounded-circle d-flex align-items-center justify-content-center" 
                                                 style="width: 36px; height: 36px; background-color: {{ don.categorie.couleur|default('#3498db') }}20;">
                                                <i class="fas {{ don.categorie.icone|default('fa-box') }}" 
                                                   style="color: {{ don.categorie.couleur|default('#3498db') }};"></i>
                                            </div>
                                        </div>
                                        <div class="flex-grow-1 ms-3">
                                            <div class="fw-bold">{{ don.articleDescription|slice(0, 40) }}...</div>
                                            <div class="text-muted small">
                                                {{ don.quantite }} {{ don.unite }} • {{ don.dateSoumission|date('d/m/Y') }}
                                            </div>
                                        </div>
                                        <a href="{{ path('admin_don_show', {'id': don.id}) }}" class="btn btn-sm btn-outline-primary">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript" src="https://www.gstatic.com/charts/loader.js"></script>
<script type="text/javascript">
    {{ gc_draw([chart_monthly, chart_by_category, chart_validation_rate, chart_quality_score], ['chart_monthly_dons', 'chart_by_category', 'chart_validation_rate', 'chart_quality_score']) }}
</script>
{% endblock %}