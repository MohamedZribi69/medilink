{# Styles pour les pages Dons dans le layout event (espace patient) - même style que Événements #}
.main-content .container .container { max-width: 100%; padding-left: 0; padding-right: 0; }
.main-content .container { padding-top: 0; }
.page-dons .btn-primary { background-color: var(--secondary-color); border-color: var(--secondary-color); color: #fff; }
.page-dons .btn-primary:hover { background-color: #0a7359; border-color: #0a7359; color: #fff; }
.page-dons .btn-outline-primary { color: var(--primary-color); border-color: var(--primary-color); }
.page-dons .btn-outline-primary:hover { background-color: var(--light-blue); color: var(--primary-color); border-color: var(--primary-color); }
.page-dons .form-control, .page-dons .form-select { border-radius: var(--radius); border-color: var(--medium-gray); }
.page-dons .input-group .btn { border-radius: 0 var(--radius) var(--radius) 0; }
.page-dons .text-primary { color: var(--primary-color) !important; }
.page-dons h1 { font-size: 1.75rem; color: var(--text-color); }
.page-dons .text-muted { color: var(--dark-gray) !important; }
.page-dons .badge.bg-success { background-color: var(--success-color) !important; }
.page-dons .badge.bg-warning { background-color: var(--warning-color) !important; color: #1a1a1a; }
.page-dons .badge.bg-danger { background-color: var(--error-color) !important; }

/* Cartes dons = même style que event-card (Événements) */
.page-dons .dons-cards { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 24px; margin-top: 24px; }
.page-dons .don-card { background: var(--white); border-radius: 12px; box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08); overflow: hidden; border: 1px solid var(--medium-gray); transition: transform 0.2s ease, box-shadow 0.2s ease; display: flex; flex-direction: column; }
.page-dons .don-card:hover { transform: translateY(-4px); box-shadow: 0 8px 28px rgba(26, 115, 232, 0.15); }
.page-dons .don-card-header { color: var(--white); padding: 20px; text-align: center; }
.page-dons .don-card-header h3 { margin: 0; font-size: 1.25rem; font-weight: 600; line-height: 1.3; }
.page-dons .don-card-header .don-category { display: inline-block; margin-top: 8px; font-size: 0.8rem; opacity: 0.95; font-weight: 500; }
.page-dons .don-card-body { padding: 20px; flex: 1; display: flex; flex-direction: column; gap: 12px; }
.page-dons .don-card-meta { display: flex; flex-direction: column; gap: 8px; color: var(--dark-gray); font-size: 0.95rem; }
.page-dons .don-card-meta span { display: flex; align-items: center; gap: 10px; }
.page-dons .don-card-meta i { width: 20px; color: var(--primary-color); font-size: 0.9rem; }
.page-dons .don-card-desc { font-size: 0.9rem; color: var(--dark-gray); line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; min-height: 4.2em; }
.page-dons .don-card-footer { padding: 16px 20px; border-top: 1px solid var(--light-gray); background: var(--light-gray); }
.page-dons .don-card .btn-don-action { display: inline-flex; align-items: center; justify-content: center; gap: 8px; width: 100%; padding: 12px 20px; background: var(--secondary-color); color: var(--white); border: none; border-radius: 8px; font-weight: 600; font-size: 1rem; text-decoration: none; cursor: pointer; transition: background 0.2s, transform 0.15s; }
.page-dons .don-card .btn-don-action:hover { background: #0a6b5a; transform: translateY(-1px); color: var(--white); }
.page-dons .dons-empty { text-align: center; padding: 48px 24px; background: var(--white); border-radius: 12px; color: var(--dark-gray); font-size: 1.1rem; }
.page-dons .dons-empty i { font-size: 3rem; color: var(--medium-gray); margin-bottom: 16px; display: block; }

/* Barre recherche + tri + filtres (même style que section événements / admin) */
.page-dons .dons-toolbar { display: flex; flex-wrap: wrap; gap: 12px; align-items: center; margin-bottom: 24px; }
.page-dons .dons-toolbar .searchbox { display: flex; align-items: center; gap: 10px; flex: 1; min-width: 220px; background: var(--white); padding: 10px 14px; border-radius: var(--radius); box-shadow: var(--shadow); border-left: 4px solid var(--primary-color); }
.page-dons .dons-toolbar .searchbox input { border: none; outline: none; width: 100%; font-size: 1rem; background: transparent; }
.page-dons .dons-toolbar .searchbox i { color: var(--primary-color); font-size: 0.95rem; }
.page-dons .dons-toolbar .filters { display: flex; gap: 10px; align-items: center; flex-wrap: wrap; }
.page-dons .dons-toolbar .filters select { min-width: 140px; padding: 10px 12px; border: 1px solid var(--medium-gray); border-radius: var(--radius); background: var(--white); font-size: 0.95rem; color: var(--text-color); }
.page-dons .dons-toolbar .filters select:focus { outline: none; border-color: var(--primary-color); }
.page-dons .dons-toolbar .btn-submit { padding: 10px 16px; background: var(--primary-color); color: var(--white); border: none; border-radius: var(--radius); font-weight: 500; cursor: pointer; display: inline-flex; align-items: center; gap: 8px; }
.page-dons .dons-toolbar .btn-submit:hover { background: #0d62d9; color: var(--white); }

/* Formulaire (nouveau don, etc.) = même style que formulaires événement */
.page-dons .form-section { background: var(--white); border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.08); border: 1px solid var(--medium-gray); overflow: hidden; margin-bottom: 24px; }
.page-dons .form-section-header { background: linear-gradient(135deg, var(--primary-color), #0d62d9); color: var(--white); padding: 16px 20px; }
.page-dons .form-section-header h3 { margin: 0; font-size: 1.15rem; font-weight: 600; display: flex; align-items: center; gap: 10px; }
.page-dons .form-section-body { padding: 24px; }
.page-dons .form-section .form-group { margin-bottom: 16px; }
.page-dons .form-section .form-group label { display: block; margin-bottom: 6px; font-weight: 500; color: var(--text-color); }
.page-dons .form-section .form-group .input,
.page-dons .form-section .form-group select.input { width: 100%; padding: 10px 14px; border: 1px solid var(--medium-gray); border-radius: var(--radius); font-size: 1rem; background: var(--white); }
.page-dons .form-section .form-row { display: flex; gap: 16px; flex-wrap: wrap; }
.page-dons .form-section .form-row .form-group { flex: 1; min-width: 180px; }
.page-dons .form-section .form-actions { display: flex; gap: 12px; margin-top: 24px; flex-wrap: wrap; }
.page-dons .form-section .form-actions .btn-primary { padding: 12px 24px; border-radius: var(--radius); font-weight: 600; display: inline-flex; align-items: center; gap: 8px; text-decoration: none; border: none; cursor: pointer; background: var(--secondary-color); color: var(--white); }
.page-dons .form-section .form-actions .btn-secondary { padding: 12px 24px; border-radius: var(--radius); font-weight: 600; display: inline-flex; align-items: center; gap: 8px; text-decoration: none; background: var(--white); color: var(--primary-color); border: 2px solid var(--primary-color); cursor: pointer; }
.page-dons .form-section .hint, .page-dons .form-section .text-muted { font-size: 0.9rem; color: var(--dark-gray); margin-top: 4px; }
.page-dons .form-section .form-error { color: var(--error-color); font-size: 0.9rem; margin-top: 4px; }
.page-dons .form-section .alert-info { padding: 14px 18px; background: var(--light-blue); border-left: 4px solid var(--primary-color); border-radius: var(--radius); font-size: 0.95rem; margin-bottom: 20px; }

/* Mes dons : statistiques (style stat-card) */
.page-dons .mes-dons-stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 16px; margin-bottom: 28px; }
.page-dons .mes-dons-stats .stat-card { background: var(--white); padding: 20px; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.08); text-align: center; border-top: 4px solid var(--medium-gray); }
.page-dons .mes-dons-stats .stat-card.stat-total { border-top-color: var(--primary-color); }
.page-dons .mes-dons-stats .stat-card.stat-attente { border-top-color: #f59e0b; }
.page-dons .mes-dons-stats .stat-card.stat-valides { border-top-color: var(--success-color); }
.page-dons .mes-dons-stats .stat-card.stat-rejetes { border-top-color: var(--error-color); }
.page-dons .mes-dons-stats .stat-card .stat-number { font-size: 2rem; font-weight: 700; color: var(--text-color); }
.page-dons .mes-dons-stats .stat-card .stat-label { font-size: 0.9rem; color: var(--dark-gray); margin-top: 4px; }

/* Mes dons : liste en cartes (même style que Dons disponibles / Événements) */
.page-dons .mes-dons-cards { display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 24px; }
.page-dons .mes-dons-card { background: var(--white); border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.08); overflow: hidden; border: 1px solid var(--medium-gray); transition: transform 0.2s ease, box-shadow 0.2s ease; display: flex; flex-direction: column; }
.page-dons .mes-dons-card:hover { transform: translateY(-4px); box-shadow: 0 8px 28px rgba(26, 115, 232, 0.15); }
.page-dons .mes-dons-card-header { color: var(--white); padding: 16px 20px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 10px; }
.page-dons .mes-dons-card-header .mes-dons-card-title { margin: 0; font-size: 1.1rem; font-weight: 600; display: flex; align-items: center; gap: 10px; }
.page-dons .mes-dons-card-header .mes-dons-card-id { font-size: 0.85rem; opacity: 0.9; }
.page-dons .mes-dons-card-header .mes-dons-card-badge { padding: 6px 12px; border-radius: 20px; font-size: 0.8rem; font-weight: 600; background: rgba(255,255,255,0.25); }
.page-dons .mes-dons-card-body { padding: 20px; flex: 1; display: flex; flex-direction: column; gap: 12px; }
.page-dons .mes-dons-card-body .mes-dons-card-desc { font-size: 1rem; font-weight: 500; color: var(--text-color); line-height: 1.4; }
.page-dons .mes-dons-card-body .mes-dons-card-details { font-size: 0.9rem; color: var(--dark-gray); line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.page-dons .mes-dons-card-meta { display: grid; grid-template-columns: 1fr 1fr; gap: 10px 16px; font-size: 0.9rem; }
.page-dons .mes-dons-card-meta .meta-item { display: flex; flex-direction: column; gap: 2px; }
.page-dons .mes-dons-card-meta .meta-label { color: var(--dark-gray); font-size: 0.8rem; }
.page-dons .mes-dons-card-meta .meta-value { font-weight: 500; color: var(--text-color); }
.page-dons .mes-dons-card-meta .badge { display: inline-block; padding: 4px 10px; border-radius: 20px; font-size: 0.75rem; font-weight: 600; width: fit-content; }
.page-dons .mes-dons-card-actions { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 8px; }
.page-dons .mes-dons-card-actions a, .page-dons .mes-dons-card-actions button { padding: 10px 16px; border-radius: 8px; font-size: 0.9rem; font-weight: 500; display: inline-flex; align-items: center; gap: 8px; text-decoration: none; cursor: pointer; border: none; transition: all 0.2s; }
.page-dons .mes-dons-card-actions .btn-edit { background: var(--primary-color); color: var(--white); }
.page-dons .mes-dons-card-actions .btn-edit:hover { background: #0d62d9; color: var(--white); }
.page-dons .mes-dons-card-actions .btn-cancel { background: var(--white); color: var(--error-color); border: 2px solid var(--error-color); }
.page-dons .mes-dons-card-actions .btn-cancel:hover { background: rgba(234, 67, 53, 0.1); }
.page-dons .mes-dons-card-actions .btn-delete { background: var(--error-color); color: var(--white); }
.page-dons .mes-dons-card-actions .btn-delete:hover { background: #c5221f; color: var(--white); }
.page-dons .mes-dons-card-status { padding: 12px 16px; border-radius: 8px; font-size: 0.9rem; margin-top: 12px; display: flex; align-items: center; gap: 10px; }
.page-dons .mes-dons-card-status.status-success { background: #e6f4ea; border-left: 4px solid var(--success-color); color: #137333; }
.page-dons .mes-dons-card-status.status-danger { background: #fce8e6; border-left: 4px solid var(--error-color); color: #c5221f; }
.page-dons .mes-dons-card-status.status-secondary { background: var(--light-gray); border-left: 4px solid var(--medium-gray); color: var(--dark-gray); }
.page-dons .mes-dons-card-footer { padding: 12px 20px; border-top: 1px solid var(--light-gray); background: var(--light-gray); font-size: 0.8rem; color: var(--dark-gray); }
.page-dons .mes-dons-empty { text-align: center; padding: 48px 24px; background: var(--white); border-radius: 12px; color: var(--dark-gray); font-size: 1.1rem; box-shadow: 0 4px 20px rgba(0,0,0,0.08); border: 1px solid var(--medium-gray); }
.page-dons .mes-dons-empty i { font-size: 3rem; color: var(--medium-gray); margin-bottom: 16px; display: block; }
.page-dons .mes-dons-empty .btn-primary { margin-top: 16px; }
