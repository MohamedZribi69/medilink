{% extends 'security/auth_base.html.twig' %}

{% block title %}Mot de passe oublié | MediLink{% endblock %}

{% block content %}
  <div class="auth-head">
    <h1><i class="fa-solid fa-key"></i> Mot de passe oublié</h1>
  </div>

  <div class="auth-body">
    {% for label, messages in app.flashes %}
      {% for message in messages %}
        <div class="alert alert-{{ label == 'success' ? 'success' : 'error' }}">
          {{ message }}
        </div>
      {% endfor %}
    {% endfor %}

    <form method="post">
      <div class="form-group">
        <label for="forgot_email"><i class="fa-solid fa-envelope"></i> Email du compte</label>
        <input
          id="forgot_email"
          name="email"
          type="email"
          required
          class="input"
          autocomplete="email"
          value="{{ last_email ?? '' }}"
          placeholder="ex: user@medilink.tn"
        >
      </div>

      <button class="btn-primary" type="submit">
        <i class="fa-solid fa-paper-plane"></i> Envoyer un nouveau mot de passe
      </button>
    </form>

    <p class="hint" style="margin-top:16px;">
      <a class="link" href="{{ path('app_login') }}">&#8592; Retour à la page de connexion</a>
    </p>
  </div>
{% endblock %}

