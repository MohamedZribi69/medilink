{% extends 'front/base.html.twig' %}

{% block title %}Accueil - MediLink{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="text-center mb-5">
                <h1 class="display-5 fw-bold mb-3">
                    <i class="fas fa-heartbeat text-primary me-2"></i> Bienvenue
                </h1>
                <p class="lead text-muted">
                    Bienvenue sur MediLink.
                </p>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-body p-4 p-md-5">
                    <h2 class="h5 mb-3">À propos de MediLink</h2>
                    <p class="text-muted mb-3">
                        MediLink est une plateforme qui met en relation les donateurs et les structures de santé. 
                        Vous pouvez y proposer des dons de matériel médical, de médicaments ou de fournitures, 
                        qui seront validés par notre équipe puis mis à disposition des centres qui en ont besoin.
                    </p>
                    <p class="text-muted mb-0">
                        Utilisez le menu ci-dessus pour accéder aux <strong>Dons disponibles</strong>, <strong>Faire un don</strong> ou consulter <strong>Mes dons</strong>.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
