{# templates/front/base.html.twig #}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}MediLink - Gestion des rendez-vous{% endblock %}</title>
    
    {% block stylesheets %}
        <!-- Bootstrap 5 -->
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        <!-- Font Awesome -->
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
        <!-- Google Fonts -->
        <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&family=Roboto:wght@300;400;500&display=swap" rel="stylesheet">
        <!-- CSS personnalisé -->
        <link rel="stylesheet" href="{{ asset('css/front.css') }}">
        {% block styles %}{% endblock %}
    {% endblock %}
</head>
<body>
    <!-- Navigation SANS lien admin -->
    <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm">
        <div class="container">
            <a class="navbar-brand" href="{{ path('front_home') }}">
                <i class="fas fa-heartbeat text-primary me-2"></i>
                <span class="fw-bold">Medi</span><span class="text-primary">Link</span>
            </a>
            
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link {{ app.request.get('_route') == 'front_home' ? 'active' : '' }}" href="{{ path('front_home') }}">
                            <i class="fas fa-home me-1"></i> Accueil
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link {{ (app.request.get('_route')|default('')) starts with 'front_don' ? 'active' : '' }}" href="{{ path('front_don_liste') }}">
                            <i class="fas fa-hand-holding-medical me-1"></i> Dons
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link {{ app.request.get('_route') == 'app_events_index' ? 'active' : '' }}" href="{{ path('app_events_index') }}">
                            <i class="fas fa-calendar-day me-1"></i> Événements
                        </a>
                    </li>
                    {% if app.user %}
                    <li class="nav-item">
                        <a class="nav-link {{ (app.request.get('_route')|default('')) starts with 'patient_rendezvous' ? 'active' : '' }}" href="{{ path('patient_rendezvous_index') }}">
                            <i class="fas fa-calendar-check me-1"></i> Rendez-vous
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link {{ (app.request.get('_route')|default('')) starts with 'patient_medicaments' or app.request.get('_route') == 'patient_medicament_show' ? 'active' : '' }}" href="{{ path('patient_medicaments_index') }}">
                            <i class="fas fa-pills me-1"></i> Médicaments
                        </a>
                    </li>
                    {% endif %}
                </ul>
                
                <div class="d-flex align-items-center gap-2">
                    {% if is_granted('ROLE_ADMIN') %}
                        <a href="{{ path('admin_dashboard') }}" class="btn btn-outline-secondary btn-sm">
                            <i class="fas fa-cog me-1"></i> Admin
                        </a>
                    {% elseif is_granted('ROLE_MEDECIN') %}
                        <a href="{{ path('medecin_index') }}" class="btn btn-outline-secondary btn-sm">
                            <i class="fas fa-user-md me-1"></i> Espace Médecin
                        </a>
                    {% elseif is_granted('ROLE_USER') %}
                        <a href="{{ path('patient_rendezvous_index') }}" class="btn btn-outline-secondary btn-sm">
                            <i class="fas fa-user me-1"></i> Espace Patient
                        </a>
                    {% endif %}
                    {% if app.user %}
                        <a href="{{ path('app_logout') }}" class="btn btn-outline-danger btn-sm">
                            <i class="fas fa-sign-out-alt me-1"></i> Déconnexion
                        </a>
                    {% else %}
                        <a href="{{ path('app_login') }}" class="btn btn-outline-primary btn-sm">
                            <i class="fas fa-sign-in-alt me-1"></i> Connexion
                        </a>
                        <a href="{{ path('app_register') }}" class="btn btn-primary btn-sm">
                            <i class="fas fa-user-plus me-1"></i> Inscription
                        </a>
                    {% endif %}
                    <a href="mailto:contact@medilink.org" class="btn btn-outline-primary btn-sm">
                        <i class="fas fa-envelope"></i> Contact
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <!-- Messages flash -->
    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show m-0 rounded-0" role="alert">
            <div class="container">
                <i class="fas fa-check-circle me-2"></i> {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        </div>
    {% endfor %}
    
    {% for message in app.flashes('error') %}
        <div class="alert alert-danger alert-dismissible fade show m-0 rounded-0" role="alert">
            <div class="container">
                <i class="fas fa-exclamation-circle me-2"></i> {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        </div>
    {% endfor %}

    <!-- Contenu principal -->
    <main class="flex-grow-1">
        {% block body %}{% endblock %}
    </main>

    <!-- Footer -->
    <footer class="bg-dark text-white py-4 mt-5">
        <div class="container">
            <div class="row">
                <div class="col-md-4">
                    <h5 class="mb-3">
                        <i class="fas fa-heartbeat me-2"></i>MediLink
                    </h5>
                    <p class="text-muted">
                        Plateforme de gestion des rendez-vous médicaux.
                    </p>
                </div>
                <div class="col-md-4">
                    <h5 class="mb-3">Liens rapides</h5>
                    <ul class="list-unstyled">
                        <li><a href="{{ path('front_don_liste') }}" class="text-muted text-decoration-none">Dons</a></li>
                        <li><a href="{{ path('app_events_index') }}" class="text-muted text-decoration-none">Événements</a></li>
                        <li><a href="{{ path('patient_rendezvous_index') }}" class="text-muted text-decoration-none">Rendez-vous</a></li>
                    </ul>
                </div>
                <div class="col-md-4">
                    <h5 class="mb-3">Contact</h5>
                    <ul class="list-unstyled text-muted">
                        <li><i class="fas fa-envelope me-2"></i> contact@medilink.org</li>
                        <li><i class="fas fa-phone me-2"></i> 01 23 45 67 89</li>
                        <li><i class="fas fa-map-marker-alt me-2"></i> 123 Rue de la Santé, 75000 Paris</li>
                    </ul>
                </div>
            </div>
            <hr class="bg-secondary my-3">
            <div class="text-center text-muted">
                <small>MediLink © {{ "now"|date("Y") }} - Gestion des rendez-vous médicaux</small>
            </div>
        </div>
    </footer>

    {% block javascripts %}
        <!-- Bootstrap 5 JS Bundle -->
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
        <!-- JavaScript personnalisé -->
        <script src="{{ asset('js/front.js') }}"></script>
        {% block page_scripts %}{% endblock %}
    {% endblock %}
</body>
</html>