{% extends app.user ? 'event/base.html.twig' : 'front/base.html.twig' %}

{% block title %}Soumettre un don - MediLink{% endblock %}
{% block event_styles %}{{ parent() }}<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">{{ include('_dons_event_styles.html.twig') }}<style>
    .unit-indicator { position: absolute; right: 12px; top: 50%; transform: translateY(-50%); color: var(--dark-gray); font-size: 0.9rem; pointer-events: none; }
    .form-group { position: relative; }
</style>{% endblock %}
{% block styles %}
<style>
    .unit-indicator {
        position: absolute;
        right: 12px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--dark-gray);
        font-size: 0.9rem;
        pointer-events: none;
    }
    .form-group {
        position: relative;
    }
</style>
{% endblock %}

{% block body %}
<div class="container py-5 page-dons">
    <div class="row">
        <div class="col-lg-8">
            <!-- En-tête -->
            <div class="section-header" style="margin-bottom: 24px;">
                <h2 style="font-size: 1.75rem; color: var(--primary-color); margin-bottom: 8px; display: flex; align-items: center; gap: 10px;">
                    <i class="fas fa-plus-circle"></i> Soumettre un don
                </h2>
                <p style="color: var(--dark-gray); font-size: 1.05rem;">
                    Remplissez ce formulaire pour soumettre votre don. Notre équipe l'examinera rapidement.
                </p>
            </div>
            
            <!-- Formulaire (style section comme Événements) -->
            <div class="form-section">
                <div class="form-section-header">
                    <h3><i class="fas fa-edit"></i> Formulaire de don</h3>
                </div>
                <div class="form-section-body">
                    {{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': 'novalidate'}}) }}
                    {{ form_errors(form) }}
                    
                    <div class="form-row">
                        <div class="form-group">
                            {{ form_label(form.categorie) }}
                            {{ form_widget(form.categorie, {'attr': {'class': 'input'}}) }}
                            <div class="invalid-feedback form-error">Veuillez sélectionner une catégorie.</div>
                        </div>
                        <div class="form-group">
                            {{ form_label(form.quantite) }}
                            <span class="unit-indicator" id="unitIndicator">unités</span>
                            {{ form_widget(form.quantite, {'attr': {'class': 'input'}}) }}
                            <div class="invalid-feedback form-error">Veuillez saisir une quantité valide.</div>
                        </div>
                    </div>
                    
                    <div class="form-group">
                        {{ form_label(form.articleDescription) }}
                        {{ form_widget(form.articleDescription, {'attr': {'class': 'input'}}) }}
                        <div class="invalid-feedback form-error">Veuillez décrire l'article.</div>
                    </div>
                    
                    <div class="form-group">
                        {{ form_label(form.detailsSupplementaires) }}
                        {{ form_widget(form.detailsSupplementaires, {'attr': {'class': 'input', 'rows': 3}}) }}
                        <span class="hint">Ex: Date d'expiration, marque, conditions de stockage...</span>
                    </div>
                    
                    <div class="form-row">
                        <div class="form-group">
                            {{ form_label(form.etat) }}
                            {{ form_widget(form.etat, {'attr': {'class': 'input'}}) }}
                        </div>
                        <div class="form-group">
                            {{ form_label(form.niveauUrgence) }}
                            {{ form_widget(form.niveauUrgence, {'attr': {'class': 'input'}}) }}
                        </div>
                    </div>
                    
                    <div class="form-row">
                        <div class="form-group">
                            {{ form_label(form.unite) }}
                            {{ form_widget(form.unite, {'attr': {'class': 'input'}}) }}
                        </div>
                        <div class="form-group">
                            {{ form_label(form.dateExpiration) }}
                            {{ form_widget(form.dateExpiration, {'attr': {'class': 'input'}}) }}
                            {{ form_errors(form.dateExpiration) }}
                        </div>
                    </div>
                    
                    <div class="alert-info">
                        <i class="fas fa-info-circle"></i>
                        <strong>Information importante :</strong>
                        Votre don sera examiné par notre équipe avant d'apparaître sur le site.
                        Vous pouvez suivre son statut dans la section « Mes dons ».
                    </div>
                    
                    <div class="form-actions">
                        <button type="reset" class="btn-secondary">
                            <i class="fas fa-eraser"></i> Effacer
                        </button>
                        <button type="submit" class="btn-primary">
                            <i class="fas fa-paper-plane"></i> Soumettre le don
                        </button>
                    </div>
                    
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
        
        <!-- Sidebar -->
        <div class="col-lg-4 mt-5 mt-lg-0">
            <!-- Catégories disponibles -->
            <div class="card shadow mb-4">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-tags me-2"></i> Catégories disponibles
                    </h5>
                </div>
                <div class="card-body">
                    <div class="list-group list-group-flush">
                        {% for categorie in categories %}
                            <div class="list-group-item border-0 px-0">
                                <div class="d-flex align-items-center">
                                    <div class="rounded-circle d-flex align-items-center justify-content-center me-3" 
                                         style="width: 36px; height: 36px; background-color: {{ categorie.couleur|default('#3498db') }}20;">
                                        <i class="fas {{ categorie.icone|default('fa-box') }}" 
                                           style="color: {{ categorie.couleur|default('#3498db') }};"></i>
                                    </div>
                                    <div>
                                        <strong>{{ categorie.nom }}</strong>
                                        {% if categorie.description %}
                                            <div class="text-muted small">{{ categorie.description }}</div>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
            
            <!-- Conseils -->
            <div class="card shadow">
                <div class="card-header bg-warning text-dark">
                    <h5 class="mb-0">
                        <i class="fas fa-lightbulb me-2"></i> Conseils importants
                    </h5>
                </div>
                <div class="card-body">
                    <ul class="list-unstyled">
                        <li class="mb-3">
                            <i class="fas fa-check-circle text-success me-2"></i>
                            <strong>Vérifiez les dates d'expiration</strong>
                            <p class="text-muted small mb-0">Les médicaments expirés ne peuvent être acceptés.</p>
                        </li>
                        <li class="mb-3">
                            <i class="fas fa-check-circle text-success me-2"></i>
                            <strong>Décrivez précisément</strong>
                            <p class="text-muted small mb-0">Nom, dosage, quantité exacte.</p>
                        </li>
                        <li class="mb-3">
                            <i class="fas fa-check-circle text-success me-2"></i>
                            <strong>État réel</strong>
                            <p class="text-muted small mb-0">Indiquez l'état réel du matériel.</p>
                        </li>
                        <li>
                            <i class="fas fa-check-circle text-success me-2"></i>
                            <strong>Emballage sécurisé</strong>
                            <p class="text-muted small mb-0">Assurez un emballage approprié.</p>
                        </li>
                    </ul>
                </div>
            </div>
            
            <!-- Suivi -->
            <div class="card shadow mt-4">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-history me-2"></i> Suivi
                    </h5>
                </div>
                <div class="card-body">
                    <p class="mb-3">
                        <i class="fas fa-clock text-warning me-2"></i>
                        <strong>Temps de traitement :</strong>
                        <span class="text-muted">24-48 heures</span>
                    </p>
                    <a href="{{ path('front_don_mes_dons') }}" class="btn-secondary" style="width: 100%; justify-content: center;">
                        <i class="fas fa-list"></i> Voir mes dons
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

{% block page_scripts %}
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Mise à jour de l'unité
    const categorySelect = document.querySelector('#{{ form.categorie.vars.id }}');
    const uniteSelect = document.querySelector('#{{ form.unite.vars.id }}');
    const uniteIndicator = document.getElementById('unitIndicator');
    
    function updateUnit() {
        if (uniteSelect && uniteIndicator) {
            const selectedOption = uniteSelect.options[uniteSelect.selectedIndex];
            if (selectedOption) {
                uniteIndicator.textContent = selectedOption.text;
            }
        }
    }
    
    // Mettre à jour quand l'unité change
    if (uniteSelect) {
        uniteSelect.addEventListener('change', updateUnit);
        updateUnit(); // Initialiser
    }
    
    // Validation du formulaire
    const form = document.querySelector('form');
    form.addEventListener('submit', function(event) {
        if (!form.checkValidity()) {
            event.preventDefault();
            event.stopPropagation();
        }
        form.classList.add('was-validated');
    }, false);
    
    // Confirmation avant soumission
    form.addEventListener('submit', function(e) {
        const submitBtn = this.querySelector('button[type="submit"]');
        const originalText = submitBtn.innerHTML;
        
        submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i> Envoi en cours...';
        submitBtn.disabled = true;
        
        setTimeout(() => {
            submitBtn.innerHTML = originalText;
            submitBtn.disabled = false;
        }, 3000);
    });
});
</script>
{% endblock %}
{% endblock %}